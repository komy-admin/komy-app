{
  "expo": {
    "name": "Fork-it",
    "slug": "Fork-it-app",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "unspecified",
    "icon": "./assets/images/icon_fork_it.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon_fork_it.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.forkit"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_fork_it.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.forkit",
      "usesCleartextTraffic": true,
      "networkSecurityConfig": "./android/network_security_config.xml",
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon_fork_it.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "fontFamily": "Mona-Sans",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7fda7163-fab5-4b74-81aa-fe8b50e76026"
      }
    }
  }
}